{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/app/data/db/Authentication.db",
    "Mahjong": "Data Source=/app/data/db/Mahjong.db"
  },
  "AppSettings": {
    "AdminUserName": "webadmin",
    "AdminPassword": "webadmin",
    "Highcharts": "VmVyOU5ldFdyYXAx",
    "mahjong_begin": "2017-01-01",
    "mahjong_huaThreshold": "0.5",
    "mahjong_roundCountThreshold": "30",
    "mahjong_gameIdThreshold": "4",
    "mahjong_lastPlayDateThreshold": "180"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "/app/data/logs/log.txt",
          "rollingInterval": "Infinite",
          "rollOnFileSizeLimit": true,
          "fileSizeLimitBytes": 10485760
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "AllowedHosts": "*"
}